    </div>
    <div class="level-filters" style="justify-content: center; margin-bottom: 24px;" id="categoryFilterContainer"></div>
    <div id="cardsContainer" class="cards-grid"></div>
    <div class="pagination" id="paginationContainer"></div>
    <div class="info-badge">✨ Kartın üzərinə klikləyin — tərcüməsi açılır | 🔊 Səsləndir | Supabase-dən canlı məlumatlar</div>
</div>
<div class="theme-toggle" id="themeToggle">🌙</div>
<div id="welcomeOverlay" class="welcome-overlay">
    <div class="welcome-card">
        <h2>🌍 Xoş gəldiniz!</h2>
        <p>Hansı dili öyrənmək istədiyinizi seçin. Sözlər Supabase-dən gəlir!</p>
        <div class="lang-selector" id="welcomeLangSelector"></div>
        <button class="welcome-btn" id="confirmLangBtn">Başla</button>
    </div>
</div>
<div id="listModal" class="modal-overlay">
    <div class="modal-content">
        <h3 id="modalTitle">📋 Siyahı</h3>
        <div id="modalListContainer" class="modal-list"></div>
        <div class="modal-buttons">
            <button id="modalClearBtn" class="modal-clear-btn">🗑️ Təmizlə</button>
            <button id="modalCloseBtn" class="modal-close-btn">Bağla</button>
        </div>
    </div>
</div>

<script>
    // ======================== SUPABASE KONFİQURASİYASI ========================
    const SUPABASE_URL = "https://icwpaipqqqwjpooazmcu.supabase.co";
    const SUPABASE_ANON_KEY = "sb_publishable_W5rnAxonO_Sq-EnCdlFU7Q_mkmi37yJ";
    
    let supabase = null;
    let dbConnected = false;
    let wordsData = [];
    
    // Loading elementləri
    const loadingOverlay = document.getElementById("loadingOverlay");
    function showLoading() { loadingOverlay.classList.remove("hidden"); }
    function hideLoading() { loadingOverlay.classList.add("hidden"); }
    
    // Supabase bağlantısı
    if (SUPABASE_URL && SUPABASE_ANON_KEY && !SUPABASE_ANON_KEY.includes("YOUR")) {
        try {
            supabase = supabaseJs.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
            dbConnected = true;
            console.log("✅ Supabase bağlandı!");
        } catch(e) {
            console.error("Supabase bağlantı xətası:", e);
            dbConnected = false;
        }
    } else {
        console.warn("⚠️ Supabase konfiqurasiya edilməyib.");
        dbConnected = false;
    }
    
    // Supabase-dən məlumatları yüklə
    async function loadFromSupabase() {
        showLoading();
        
        if (!dbConnected || !supabase) {
            console.error("Supabase bağlı deyil");
            hideLoading();
            renderCards();
            return;
        }
        
        try {
            const { data, error } = await supabase
                .from('words')
                .select('*')
                .order('created_at', { ascending: false });
            
            if (error) throw error;
            
            if (data && data.length > 0) {
                wordsData = data.map(row => ({
                    id: row.id.toString(),
                    az: row.az,
                    en: row.en,
                    en_read: row.en_read,
                    ru: row.ru || row.az,
                    ru_read: row.ru_read || row.az.toLowerCase(),
                    de: row.de || row.az,
                    de_read: row.de_read || row.az.toLowerCase(),
                    es: row.es || row.az,
                    es_read: row.es_read || row.az.toLowerCase(),
                    pt: row.pt || row.az,
                    pt_read: row.pt_read || row.az.toLowerCase(),
                    tr: row.tr || row.az,
                    tr_read: row.tr_read || row.az.toLowerCase(),
                    zh: row.zh || row.az,
                    zh_read: row.zh_read || row.az.toLowerCase(),
                    level: row.level || "Basic",
                    category: row.category || "Sözlər"
                }));
            } else {
                wordsData = [];
                console.log("Supabase-də heç bir məlumat yoxdur");
            }
            hideLoading();
            renderCards();
        } catch (error) {
            console.error("Supabase-dən yükləmə xətası:", error);
            wordsData = [];
            hideLoading();
            renderCards();
        }
    }
    
    // Dil seçimləri
    const languageOptions = [
        { code: "en", name: "İngiliscə", flag: "🇬🇧", textKey: "en", readKey: "en_read" },
        { code: "ru", name: "Rusca", flag: "🇷🇺", textKey: "ru", readKey: "ru_read" },
        { code: "de", name: "Almanca", flag: "🇩🇪", textKey: "de", readKey: "de_read" },
        { code: "es", name: "İspanca", flag: "🇪🇸", textKey: "es", readKey: "es_read" },
        { code: "pt", name: "Portuqalca", flag: "🇵🇹", textKey: "pt", readKey: "pt_read" },
        { code: "tr", name: "Türkcə", flag: "🇹🇷", textKey: "tr", readKey: "tr_read" },
        { code: "zh", name: "Çincə", flag: "🇨🇳", textKey: "zh", readKey: "zh_read" }
    ];
    
    let currentLang = "en", favoriteIds = new Set(), knownIds = new Set(), unknownIds = new Set(), currentLevel = "all", currentCategory = "all", showFavoritesOnly = false, currentPage = 1;
    const itemsPerPage = 50, levelsOrder = ["Basic", "Intermediate", "Advanced", "Pro"];
    
    let currentUtterance = null;
    let currentSpeakButton = null;
    
    function getTranslationText(card, langCode) { return card[langCode] || card.en; }
    function getTranslationRead(card, langCode) { const readKey = langCode + "_read"; return card[readKey] || ""; }
    
    function speakText(text, langCode, buttonElement) {
        if (currentUtterance) {
            window.speechSynthesis.cancel();
            currentUtterance = null;
            if (currentSpeakButton) {
                currentSpeakButton.innerHTML = "🔊 Səsləndir";
                currentSpeakButton.classList.remove("stop-speak-btn");
                currentSpeakButton.classList.add("speak-btn");
                currentSpeakButton = null;
            }
            if (currentSpeakButton === buttonElement) return;
        }
        if (!window.speechSynthesis || !text) return;
        const utterance = new SpeechSynthesisUtterance(text);
        const langMap = { en:"en-US", ru:"ru-RU", de:"de-DE", es:"es-ES", pt:"pt-PT", tr:"tr-TR", zh:"zh-CN" };
        utterance.lang = langMap[langCode] || "en-US";
        utterance.rate = 0.9;
        currentUtterance = utterance;
        currentSpeakButton = buttonElement;
        buttonElement.innerHTML = "⏹️ Stop";
        buttonElement.classList.remove("speak-btn");
        buttonElement.classList.add("stop-speak-btn");
        utterance.onend = () => {
            currentUtterance = null;
            if (currentSpeakButton) {
                currentSpeakButton.innerHTML = "🔊 Səsləndir";
                currentSpeakButton.classList.remove("stop-speak-btn");
                currentSpeakButton.classList.add("speak-btn");
                currentSpeakButton = null;
            }
        };
        utterance.onerror = () => {
            currentUtterance = null;
            if (currentSpeakButton) {
                currentSpeakButton.innerHTML = "🔊 Səsləndir";
                currentSpeakButton.classList.remove("stop-speak-btn");
                currentSpeakButton.classList.add("speak-btn");
                currentSpeakButton = null;
            }
        };
        window.speechSynthesis.speak(utterance);
    }
    
    // DOM elements
    const appMain = document.getElementById("appMain"), welcomeOverlay = document.getElementById("welcomeOverlay"), welcomeSelector = document.getElementById("welcomeLangSelector"), confirmLangBtn = document.getElementById("confirmLangBtn");
    const customDropdownBtn = document.getElementById("customDropdownBtn"), dropdownMenu = document.getElementById("dropdownMenu"), selectedLangText = document.getElementById("selectedLangText");
    const levelContainer = document.getElementById("levelFilterContainer"), categoryContainer = document.getElementById("categoryFilterContainer"), cardsContainer = document.getElementById("cardsContainer"), paginationContainer = document.getElementById("paginationContainer");
    const favCountSpan = document.getElementById("favCountBadge"), knownCountSpan = document.getElementById("knownCount"), unknownCountSpan = document.getElementById("unknownCount");
    const openKnownBtn = document.getElementById("openKnownModal"), openUnknownBtn = document.getElementById("openUnknownModal"), openFavBtn = document.getElementById("openFavModal");
    const modalOverlay = document.getElementById("listModal"), modalTitle = document.getElementById("modalTitle"), modalListContainer = document.getElementById("modalListContainer"), modalClearBtn = document.getElementById("modalClearBtn"), modalCloseBtn = document.getElementById("modalCloseBtn");
    const themeToggle = document.getElementById("themeToggle");
    let currentModalType = null;
    
    function buildDropdown() { dropdownMenu.innerHTML = ''; languageOptions.forEach(opt => { const item = document.createElement('div'); item.className = `dropdown-item ${currentLang === opt.code ? 'selected' : ''}`; item.innerHTML = `<span class="lang-flag">${opt.flag}</span> <span>${opt.name}</span>`; item.addEventListener('click', () => { changeLanguage(opt.code); closeDropdown(); }); dropdownMenu.appendChild(item); }); }
    function toggleDropdown() { dropdownMenu.classList.toggle('active'); }
    function closeDropdown() { dropdownMenu.classList.remove('active'); }
    function updateDropdownDisplay() { const selected = languageOptions.find(opt => opt.code === currentLang); if (selected) selectedLangText.innerHTML = `${selected.flag} ${selected.name}`; }
    document.addEventListener('click', function(e) { const wrapper = document.getElementById('langDropdownWrapper'); if (wrapper && !wrapper.contains(e.target)) closeDropdown(); });
    if (customDropdownBtn) customDropdownBtn.addEventListener('click', (e) => { e.stopPropagation(); toggleDropdown(); });
    
    function loadStorage() { try { let savedLang = localStorage.getItem("diloyren_lang"); if (savedLang && languageOptions.some(opt => opt.code === savedLang)) currentLang = savedLang; let fav = localStorage.getItem("diloyren_fav"); favoriteIds = new Set(fav ? JSON.parse(fav) : []); let known = localStorage.getItem("diloyren_known"); knownIds = new Set(known ? JSON.parse(known) : []); let unknown = localStorage.getItem("diloyren_unknown"); unknownIds = new Set(unknown ? JSON.parse(unknown) : []); } catch(e) {} updateCounters(); updateDropdownDisplay(); }
    function saveLang() { localStorage.setItem("diloyren_lang", currentLang); updateDropdownDisplay(); }
    function saveFav() { localStorage.setItem("diloyren_fav", JSON.stringify([...favoriteIds])); updateFavUI(); }
    function saveKnown() { localStorage.setItem("diloyren_known", JSON.stringify([...knownIds])); updateCounters(); }
    function saveUnknown() { localStorage.setItem("diloyren_unknown", JSON.stringify([...unknownIds])); updateCounters(); }
    function updateCounters() { knownCountSpan.innerText = knownIds.size; unknownCountSpan.innerText = unknownIds.size; }
    function updateFavUI() { favCountSpan.innerText = favoriteIds.size; }
    function setKnown(id, e) { e.stopPropagation(); if(unknownIds.has(id)) unknownIds.delete(id); knownIds.add(id); saveKnown(); saveUnknown(); renderCards(); }
    function setUnknown(id, e) { e.stopPropagation(); if(knownIds.has(id)) knownIds.delete(id); unknownIds.add(id); saveKnown(); saveUnknown(); renderCards(); }
    function toggleFavorite(id, e) { e.stopPropagation(); if(favoriteIds.has(id)) favoriteIds.delete(id); else favoriteIds.add(id); saveFav(); renderCards(); }
    function handleSpeak(card, langCode, e, button) { e.stopPropagation(); const text = getTranslationText(card, langCode); speakText(text, langCode, button); }
    function clearKnown() { knownIds.clear(); saveKnown(); renderCards(); closeModal(); }
    function clearUnknown() { unknownIds.clear(); saveUnknown(); renderCards(); closeModal(); }
    function clearFav() { favoriteIds.clear(); saveFav(); renderCards(); closeModal(); }
    function openListModal(type) { currentModalType = type; let title = "", items = []; if(type === 'known') { title = "✅ Bilirəm kartları"; items = Array.from(knownIds).map(id => wordsData.find(w => w.id === id)).filter(c => c); } else if(type === 'unknown') { title = "❌ Bilmirəm kartları"; items = Array.from(unknownIds).map(id => wordsData.find(w => w.id === id)).filter(c => c); } else if(type === 'fav') { title = "⭐ Sevimli kartlar"; items = Array.from(favoriteIds).map(id => wordsData.find(w => w.id === id)).filter(c => c); } modalTitle.innerText = title; if(items.length === 0) modalListContainer.innerHTML = `<div class="empty-list">📭 Heç bir kart yoxdur</div>`; else modalListContainer.innerHTML = items.map(card => `<div class="modal-list-item"><div><span>${escapeHtml(card.az)} → ${escapeHtml(getTranslationText(card, currentLang))}</span><br><small>${card.level} | ${card.category}</small></div></div>`).join(''); modalOverlay.classList.add("active"); }
    function closeModal() { modalOverlay.classList.remove("active"); currentModalType = null; }
    function handleClear() { if(currentModalType === 'known') clearKnown(); else if(currentModalType === 'unknown') clearUnknown(); else if(currentModalType === 'fav') clearFav(); closeModal(); }
    function initTheme() { const saved = localStorage.getItem("diloyren_theme"); if(saved === "dark") { document.body.classList.add("dark"); themeToggle.innerHTML = "☀️"; } else { themeToggle.innerHTML = "🌙"; } }
    function toggleTheme() { if(document.body.classList.contains("dark")) { document.body.classList.remove("dark"); localStorage.setItem("diloyren_theme", "light"); themeToggle.innerHTML = "🌙"; } else { document.body.classList.add("dark"); localStorage.setItem("diloyren_theme", "dark"); themeToggle.innerHTML = "☀️"; } }
    function attachClickFlip(cardElement) { cardElement.addEventListener("click", (e) => { if(e.target.closest('.star-icon') || e.target.closest('.know-btn') || e.target.closest('.dontknow-btn') || e.target.closest('.speak-btn') || e.target.closest('.stop-speak-btn')) return; cardElement.classList.toggle('flipped'); }); }
    function getAllCategoriesSorted() { const cats = [...new Set(wordsData.map(c => c.category))]; cats.sort(); return cats; }
    function getFilteredCards() { let filtered = [...wordsData]; if(currentLevel !== "all") filtered = filtered.filter(c => c.level === currentLevel); if(currentCategory !== "all") filtered = filtered.filter(c => c.category === currentCategory); if(showFavoritesOnly) filtered = filtered.filter(c => favoriteIds.has(c.id)); return filtered; }
    function renderPagination(totalItems) { const totalPages = Math.ceil(totalItems / itemsPerPage); paginationContainer.innerHTML = ''; if (totalPages <= 1) return; const prevBtn = document.createElement('button'); prevBtn.textContent = '← Əvvəl'; prevBtn.className = 'page-btn'; prevBtn.disabled = currentPage === 1; prevBtn.onclick = () => { if (currentPage > 1) { currentPage--; renderCards(); } }; paginationContainer.appendChild(prevBtn); for (let i = 1; i <= Math.min(totalPages, 5); i++) { const btn = document.createElement('button'); btn.textContent = i; btn.className = `page-btn ${currentPage === i ? 'active' : ''}`; btn.onclick = () => { currentPage = i; renderCards(); }; paginationContainer.appendChild(btn); } const nextBtn = document.createElement('button'); nextBtn.textContent = 'Sonra →'; nextBtn.className = 'page-btn'; nextBtn.disabled = currentPage === totalPages; nextBtn.onclick = () => { if (currentPage < totalPages) { currentPage++; renderCards(); } }; paginationContainer.appendChild(nextBtn); }
    function renderCards() { 
        const filtered = getFilteredCards(); 
        const totalItems = filtered.length; 
        const totalPages = Math.ceil(totalItems / itemsPerPage); 
        if (currentPage > totalPages) currentPage = 1; 
        const start = (currentPage - 1) * itemsPerPage; 
        const end = start + itemsPerPage; 
        const pageCards = filtered.slice(start, end); 
        
        if (pageCards.length === 0) { 
            cardsContainer.innerHTML = `<div class="empty-msg">📭 Kart yoxdur</div>`; 
            renderPagination(0); 
            return; 
        } 
        
        cardsContainer.innerHTML = ""; 
        pageCards.forEach(card => { 
            const isFav = favoriteIds.has(card.id); 
            const isKnown = knownIds.has(card.id); 
            const isUnknown = unknownIds.has(card.id); 
            const backText = getTranslationText(card, currentLang); 
            const backRead = getTranslationRead(card, currentLang); 
            const flipDiv = document.createElement("div"); flipDiv.className = "flip-card"; 
            const inner = document.createElement("div"); inner.className = "flip-card-inner"; 
            const front = document.createElement("div"); front.className = "card-front"; 
            front.innerHTML = `<div class="top-info"><div class="left-info"><div class="category-badge">📁 ${escapeHtml(card.category)}</div><div class="level-badge">${card.level}</div></div></div><div style="flex:1; display:flex; flex-direction:column; justify-content:center;"><div class="main-word">${escapeHtml(card.az)}</div></div><div><div class="action-buttons"><button class="know-btn ${isKnown ? 'active-know' : ''}">✅ Bilirəm</button><button class="dontknow-btn ${isUnknown ? 'active-unknown' : ''}">❌ Bilmirəm</button></div></div>`; 
            const back = document.createElement("div"); back.className = "card-back"; 
            back.innerHTML = `<div><div class="main-word" style="font-size:1rem;">${escapeHtml(backText)}</div>${backRead ? `<div class="pronunciation">🔊 ${escapeHtml(backRead)}</div>` : ''}<button class="speak-btn" style="margin-top: 12px;">🔊 Səsləndir</button></div><div style="margin-top:12px; font-size:0.6rem; opacity:0.6;">📘 ${escapeHtml(card.az)}</div>`; 
            inner.appendChild(front); inner.appendChild(back); flipDiv.appendChild(inner); 
            const star = document.createElement("div"); star.className = `star-icon ${isFav ? "favorited" : ""}`; star.innerHTML = isFav ? "⭐" : "☆"; star.addEventListener("click", (e) => toggleFavorite(card.id, e)); flipDiv.appendChild(star); 
            const knowBtn = front.querySelector(".know-btn"), dontBtn = front.querySelector(".dontknow-btn"); 
            const speakBtn = back.querySelector(".speak-btn"); 
            knowBtn.addEventListener("click", (e) => setKnown(card.id, e)); 
            dontBtn.addEventListener("click", (e) => setUnknown(card.id, e)); 
            speakBtn.addEventListener("click", (e) => { e.stopPropagation(); handleSpeak(card, currentLang, e, speakBtn); }); 
            attachClickFlip(flipDiv); cardsContainer.appendChild(flipDiv); 
        }); 
        renderPagination(totalItems); 
    }
    function escapeHtml(str) { return String(str).replace(/[&<>]/g, m => ({ '&':'&amp;', '<':'&lt;', '>':'&gt;' }[m])); }
    function buildLevelButtons() { levelContainer.innerHTML = ''; const allBtn = document.createElement('button'); allBtn.className = `level-btn ${currentLevel === "all" ? "active" : ""}`; allBtn.innerText = "Bütün Levellər"; allBtn.onclick = () => { currentLevel = "all"; showFavoritesOnly = false; currentPage = 1; updateActiveUI(); renderCards(); }; levelContainer.appendChild(allBtn); levelsOrder.forEach(lvl => { const btn = document.createElement('button'); btn.className = `level-btn ${currentLevel === lvl ? "active" : ""}`; btn.innerText = lvl; btn.onclick = () => { currentLevel = lvl; showFavoritesOnly = false; currentPage = 1; updateActiveUI(); renderCards(); }; levelContainer.appendChild(btn); }); }
    function buildCategoryButtons() { categoryContainer.innerHTML = ''; const allCat = document.createElement('button'); allCat.className = `level-btn ${currentCategory === "all" ? "active" : ""}`; allCat.innerText = "📌 Bütün Mövzular"; allCat.setAttribute("data-cat","all"); allCat.onclick = () => { currentCategory = "all"; showFavoritesOnly = false; currentPage = 1; updateActiveUI(); renderCards(); }; categoryContainer.appendChild(allCat); getAllCategoriesSorted().forEach(cat => { const btn = document.createElement('button'); btn.className = `level-btn ${currentCategory === cat ? "active" : ""}`; btn.innerText = cat; btn.setAttribute("data-cat", cat); btn.onclick = () => { currentCategory = cat; showFavoritesOnly = false; currentPage = 1; updateActiveUI(); renderCards(); }; categoryContainer.appendChild(btn); }); }
    function updateActiveUI() { document.querySelectorAll("#levelFilterContainer .level-btn").forEach(btn => { const txt = btn.innerText; if((currentLevel === "all" && txt === "Bütün Levellər") || currentLevel === txt) btn.classList.add("active"); else btn.classList.remove("active"); }); document.querySelectorAll("#categoryFilterContainer .level-btn").forEach(btn => { const cat = btn.getAttribute("data-cat"); if((currentCategory === "all" && cat === "all") || currentCategory === cat) btn.classList.add("active"); else btn.classList.remove("active"); }); }
    function changeLanguage(lang) { currentLang = lang; saveLang(); renderCards(); }
    function initWelcome() { welcomeSelector.innerHTML = languageOptions.map(opt => `<div class="lang-option" data-lang="${opt.code}">${opt.flag} ${opt.name}</div>`).join(''); document.querySelectorAll(".lang-option").forEach(el => { el.addEventListener("click", () => { currentLang = el.dataset.lang; document.querySelectorAll(".lang-option").forEach(opt => opt.style.background = ""); el.style.background = "var(--accent)"; }); }); }
    function startApp() { localStorage.setItem("diloyren_first_visit", "false"); saveLang(); welcomeOverlay.classList.remove("active"); appMain.style.display = "block"; loadFromSupabase(); }
    function checkFirstVisit() { const firstVisit = localStorage.getItem("diloyren_first_visit"); if (!firstVisit) { initWelcome(); welcomeOverlay.classList.add("active"); appMain.style.display = "none"; } else { appMain.style.display = "block"; welcomeOverlay.classList.remove("active"); loadFromSupabase(); } }
    confirmLangBtn.addEventListener("click", startApp); openKnownBtn.addEventListener("click", () => openListModal('known')); openUnknownBtn.addEventListener("click", () => openListModal('unknown')); openFavBtn.addEventListener("click", () => { showFavoritesOnly = true; currentPage = 1; renderCards(); }); modalClearBtn.addEventListener("click", handleClear); modalCloseBtn.addEventListener("click", closeModal); modalOverlay.addEventListener("click", (e) => { if(e.target === modalOverlay) closeModal(); }); themeToggle.addEventListener("click", toggleTheme);
    function init() { loadStorage(); initTheme(); buildLevelButtons(); buildCategoryButtons(); currentLevel = "all"; currentCategory = "all"; showFavoritesOnly = false; currentPage = 1; updateActiveUI(); buildDropdown(); updateDropdownDisplay(); checkFirstVisit(); }
    init();
</script>
