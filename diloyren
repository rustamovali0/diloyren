        .stats-fav-panel { display: flex; gap: 12px; flex-wrap: wrap; align-items: center; }
        .stat-card, .fav-header { background: var(--stat-bg); border-radius: 40px; padding: 6px 16px; display: flex; align-items: center; gap: 10px; font-size: 0.85rem; font-weight: 500; border: 1px solid var(--border-light); cursor: pointer; }
