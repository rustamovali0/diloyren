        .category-badge { background: var(--accent); padding: 4px 8px; border-radius: 20px; font-size: 0.6rem; font-weight: bold; color: #1e293b; display: inline-block; }
        .level-badge { background: var(--btn-bg); padding: 4px 8px; border-radius: 20px; font-size: 0.6rem; font-weight: 500; display: inline-block; }
        .top-info { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; width: 100%; }
        .left-info { display: flex; gap: 6px; align-items: center; flex-wrap: wrap; }
