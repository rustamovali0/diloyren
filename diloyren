<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Dil Öyrən - Supabase Database</title>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --bg-gradient-start: #f5f7fc; --bg-gradient-end: #e9eef4; --surface: #ffffff;
            --text-primary: #1e2a3a; --text-secondary: #4a627a; --accent: #f5a623;
            --card-front-bg: #ffffff; --card-back-bg: linear-gradient(135deg, #2c3e4e, #1e2f3b);
            --card-back-text: #FFE6C7; --border-light: #e2e8f0; --btn-bg: #f1f5f9;
            --btn-hover: #e2e8f0; --shadow-md: 0 20px 30px -12px rgba(0,0,0,0.1);
            --stat-bg: #f1f5f9; --modal-bg: rgba(0,0,0,0.5); --danger: #c44536;
            --speaker-btn: #4a6a8a;
        }
        body.dark {
            --bg-gradient-start: #0f1724; --bg-gradient-end: #0a0f18; --surface: #1e293b;
            --text-primary: #f1f5f9; --text-secondary: #94a3b8; --accent: #fbbf24;
            --card-front-bg: #334155; --card-back-bg: linear-gradient(135deg, #1e293b, #0f172a);
            --card-back-text: #fef3c7; --border-light: #334155; --btn-bg: #334155;
            --btn-hover: #475569; --stat-bg: #1e293b; --modal-bg: rgba(0,0,0,0.7);
            --danger: #e05a4a; --speaker-btn: #5a7a9a;
        }
        body { background: linear-gradient(135deg, var(--bg-gradient-start), var(--bg-gradient-end)); font-family: 'Inter', system-ui, sans-serif; color: var(--text-primary); padding: 16px; min-height: 100vh; }
        
        /* Loading ekranı */
        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.7);
            backdrop-filter: blur(8px);
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            gap: 20px;
            transition: 0.3s;
        }
        .loading-overlay.hidden { display: none; }
        .loader {
            width: 60px;
            height: 60px;
            border: 5px solid var(--border-light);
            border-top: 5px solid var(--accent);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        .loading-text { color: white; font-size: 1.2rem; font-weight: 500; }
        
        .cards-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin-top: 24px; }
        @media (min-width: 768px) { .cards-grid { grid-template-columns: repeat(3, 1fr); gap: 20px; } }
        @media (min-width: 1024px) { .cards-grid { grid-template-columns: repeat(4, 1fr); gap: 24px; } }
        
        .lang-dropdown-wrapper { position: relative; }
        .custom-dropdown { background: var(--surface); border: 1px solid var(--border-light); border-radius: 48px; padding: 8px 20px; font-size: 0.9rem; font-weight: 500; cursor: pointer; display: flex; align-items: center; gap: 8px; min-width: 160px; justify-content: space-between; }
        .custom-dropdown:hover { background: var(--btn-hover); border-color: var(--accent); }
        .dropdown-menu { position: absolute; top: calc(100% + 8px); left: 0; right: 0; background: var(--surface); border: 1px solid var(--border-light); border-radius: 24px; box-shadow: var(--shadow-md); z-index: 100; display: none; overflow: hidden; max-height: 300px; overflow-y: auto; }
        .dropdown-menu.active { display: block; animation: fadeIn 0.15s ease; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }
        .dropdown-item { padding: 12px 20px; cursor: pointer; display: flex; align-items: center; gap: 10px; transition: background 0.15s; }
        .dropdown-item:hover { background: var(--btn-hover); }
        .dropdown-item.selected { background: var(--accent); color: #1e2a36; font-weight: 600; }
        .lang-flag { font-size: 1.2rem; }
        
        .theme-toggle { position: fixed; bottom: 24px; right: 24px; width: 52px; height: 52px; border-radius: 60px; background: var(--surface); border: 1px solid var(--border-light); box-shadow: var(--shadow-md); cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 26px; z-index: 1000; }
        .app { max-width: 1400px; margin: 0 auto; }
        
        .welcome-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.85);
            backdrop-filter: blur(8px);
            z-index: 3000;
            display: flex;
            align-items: center;
            justify-content: center;
            visibility: hidden;
            opacity: 0;
            transition: 0.3s;
        }
        .welcome-overlay.active { visibility: visible; opacity: 1; }
        .welcome-card { background: var(--surface); border-radius: 48px; padding: 32px; max-width: 500px; width: 90%; text-align: center; }
        .welcome-card h2 { font-size: 1.8rem; margin-bottom: 16px; background: linear-gradient(135deg, var(--accent), #ff8c42); -webkit-background-clip: text; background-clip: text; color: transparent; }
        .lang-selector { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; margin: 20px 0; }
        .lang-option { background: var(--btn-bg); border: 1px solid var(--border-light); padding: 10px 20px; border-radius: 60px; cursor: pointer; }
        .lang-option:hover { background: var(--accent); transform: scale(1.02); }
        .welcome-btn { background: var(--accent); border: none; padding: 12px 28px; border-radius: 60px; font-weight: bold; font-size: 1rem; cursor: pointer; margin-top: 16px; }
        
        .hero { background: var(--surface); border-radius: 24px; padding: 16px 24px; margin-bottom: 24px; text-align: center; border: 1px solid var(--border-light); }
        .top-bar { background: var(--surface); border-radius: 32px; padding: 16px 24px; margin-bottom: 24px; display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 16px; border: 1px solid var(--border-light); }
        .brand h1 { font-weight: 700; font-size: 1.8rem; background: linear-gradient(135deg, var(--accent), #ff8c42); -webkit-background-clip: text; background-clip: text; color: transparent; }
        .level-filters { display: flex; flex-wrap: wrap; gap: 10px; }
