        .pagination { display: flex; justify-content: center; align-items: center; gap: 12px; margin-top: 32px; flex-wrap: wrap; }
        .page-btn { background: var(--btn-bg); border: 1px solid var(--border-light); padding: 8px 16px; border-radius: 40px; cursor: pointer; font-weight: 500; }
        .page-btn:hover { background: var(--btn-hover); }
        .page-btn.active { background: var(--accent); color: #1e2a36; border-color: var(--accent); }
        .page-btn:disabled { opacity: 0.5; cursor: not-allowed; }
        
