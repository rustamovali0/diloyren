        .know-btn, .dontknow-btn, .speak-btn, .stop-speak-btn { border: none; padding: 6px 12px; border-radius: 40px; font-weight: bold; cursor: pointer; font-size: 0.7rem; transition: all 0.2s ease; }
        .know-btn, .dontknow-btn { opacity: 0.6; }
        .know-btn { background: #2e7d64; color: white; }
        .dontknow-btn { background: #b5654b; color: white; }
        .know-btn.active-know { opacity: 1; background: #1f5a48; }
        .dontknow-btn.active-unknown { opacity: 1; background: #8a3e2a; }
        .speak-btn, .stop-speak-btn { background: var(--speaker-btn); color: white; opacity: 0.85; display: inline-flex; align-items: center; gap: 4px; font-size: 0.65rem; padding: 4px 10px; }
        .stop-speak-btn { background: #c44536; }
        
        .star-icon { position: absolute; top: 10px; right: 10px; font-size: 22px; cursor: pointer; z-index: 25; background: rgba(0,0,0,0.25); width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; border-radius: 50%; backdrop-filter: blur(4px); color: #e0e0e0; border: 1px solid #000000; }
        .star-icon.favorited { color: #FFD966; border-color: #000000; background: rgba(0,0,0,0.35); }
        .empty-msg { text-align: center; padding: 60px; background: var(--surface); border-radius: 48px; margin-top: 40px; }
        .info-badge { text-align: center; margin-top: 36px; font-size: 0.7rem; opacity: 0.5; padding: 16px; }
        
        .modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: var(--modal-bg); backdrop-filter: blur(4px); z-index: 2000; display: flex; align-items: center; justify-content: center; visibility: hidden; opacity: 0; transition: 0.2s; }
        .modal-overlay.active { visibility: visible; opacity: 1; }
        .modal-content { background: var(--surface); border-radius: 32px; padding: 24px; width: 90%; max-width: 550px; max-height: 80vh; display: flex; flex-direction: column; }
        .modal-list { flex: 1; overflow-y: auto; margin: 16px 0; max-height: 50vh; }
        .modal-list-item { padding: 12px; border-bottom: 1px solid var(--border-light); display: flex; justify-content: space-between; align-items: center; }
        .modal-buttons { display: flex; gap: 12px; margin-top: 12px; }
        .modal-clear-btn { background: var(--danger); color: white; padding: 10px; border-radius: 40px; flex: 1; cursor: pointer; }
        .modal-close-btn { background: var(--btn-bg); border: 1px solid var(--border-light); padding: 10px; border-radius: 40px; flex: 1; cursor: pointer; }
    </style>
</head>
<body>
<div class="loading-overlay" id="loadingOverlay">
